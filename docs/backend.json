
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user's profile and wallet information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "numericId": { "type": "number" },
        "authProviderId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "preferredGenders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": { "type": "string" },
        "relationshipGoal": { "type": "string" },
        "education": { "type": "string" },
        "horoscope": { "type": "string" },
        "interests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "profilePhotoUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "coinBalance": { "type": "number" },
        "diamondBalance": { "type": "number" },
        "lastCheckInDate": { "type": "string", "format": "date" },
        "checkInStreak": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isCoinseller": { "type": "boolean" },
        "isSupport": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastActiveAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authProviderId", "username", "dateOfBirth", "gender", "createdAt", "coinBalance"]
    },
    "CoinTransaction": {
      "title": "CoinTransaction",
      "description": "Represents a single coin or diamond related activity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "transactionDate": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "orderTrackingId": { "type": "string" }
      },
      "required": ["id", "type", "amount", "transactionDate"]
    },
    "CallSession": {
      "title": "CallSession",
      "description": "Stores state for active or ringing video/audio calls.",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["ringing", "accepted"] },
        "callType": { "type": "string", "enum": ["video", "audio"] },
        "timestamp": { "type": "number" },
        "callerName": { "type": "string" }
      },
      "required": ["callerId", "receiverId", "status", "callType", "timestamp"]
    },
    "Report": {
      "title": "Report",
      "description": "User feedback regarding another user's behavior or profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "reportedUserId": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "reviewed"] }
      },
      "required": ["id", "reporterId", "reportedUserId", "details", "createdAt", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile document."
    },
    "/userProfiles/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/CoinTransaction" },
      "description": "User transaction history."
    },
    "/calls/{chatId}": {
      "schema": { "$ref": "#/entities/CallSession" },
      "description": "Active call sessions."
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "User violation reports."
    }
  }
}
