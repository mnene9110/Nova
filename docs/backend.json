
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user's profile and wallet information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "numericId": { "type": "number" },
        "authProviderId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "gender": { "type": "string" },
        "preferredGenders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "location": { "type": "string" },
        "relationshipGoal": { "type": "string" },
        "education": { "type": "string" },
        "horoscope": { "type": "string" },
        "interests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "profilePhotoUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "coinBalance": { "type": "number" },
        "diamondBalance": { "type": "number" },
        "lastCheckInDate": { "type": "string", "format": "date" },
        "checkInStreak": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isCoinseller": { "type": "boolean" },
        "isSupport": { "type": "boolean" },
        "isAgent": { "type": "boolean" },
        "agencyId": { "type": "string" },
        "memberOfAgencyId": { "type": "string" },
        "agencyJoinStatus": { "type": "string", "enum": ["none", "pending", "approved"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastActiveAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authProviderId", "username", "dateOfBirth", "gender", "createdAt", "coinBalance"]
    },
    "Agency": {
      "title": "Agency",
      "description": "Represents an agency created by an agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "agentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "agentId", "createdAt"]
    },
    "CoinTransaction": {
      "title": "CoinTransaction",
      "description": "Represents a single coin or diamond related activity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "transactionDate": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "orderTrackingId": { "type": "string" }
      },
      "required": ["id", "type", "amount", "transactionDate"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile document."
    },
    "/agencies/{agencyId}": {
      "schema": { "$ref": "#/entities/Agency" },
      "description": "Agency information."
    },
    "/userProfiles/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/CoinTransaction" },
      "description": "User transaction history."
    }
  }
}
