
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check user roles
    function getUserData(userId) {
      return get(/databases/$(database)/documents/userProfiles/$(userId)).data;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isAdmin', false) == true;
    }

    function isSupport() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isSupport', false) == true;
    }

    function isCoinseller() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isCoinseller', false) == true;
    }

    // Helper to check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles security
    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      
      // Only the owner can create their own profile. Sensitive flags are protected.
      allow create: if isOwner(userId) && (
        !request.resource.data.hasAny(['isAdmin', 'isCoinseller', 'isSupport']) || 
        (request.resource.data.get('isAdmin', false) == false && 
         request.resource.data.get('isCoinseller', false) == false && 
         request.resource.data.get('isSupport', false) == false)
      );

      allow update: if (
        isOwner(userId) && (
          // Regular users can't change roles
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isCoinseller', 'isSupport']) &&
          // Balance can only be changed if it's currently 0 (onboarding case) or if it's not being changed at all
          (request.resource.data.get('coinBalance', 0) == resource.data.get('coinBalance', 0) || 
           (resource.data.get('coinBalance', 0) == 0 && request.resource.data.get('coinBalance', 0) <= 500))
        )
      ) || (
        isAdmin()
      ) || (
        isCoinseller() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coinBalance', 'updatedAt'])
      );

      // Secure sub-collections
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin() || isSupport();
        allow create: if isOwner(userId) || isAdmin() || isCoinseller();
      }

      match /blockedUsers/{blockedId} {
        allow get: if isAuthenticated() && (request.auth.uid == userId || request.auth.uid == blockedId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Reports security
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, delete: if isAdmin() || isSupport();
    }

    // Call signaling security
    match /calls/{chatId} {
      allow read, write: if isAuthenticated() && (
        chatId.split('_')[0] == request.auth.uid ||
        chatId.split('_')[1] == request.auth.uid
      );
    }

    // Default deny for all other paths
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
