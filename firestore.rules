
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/userProfiles/$(userId)).data;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isAdmin', false) == true;
    }

    function isSupport() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isSupport', false) == true;
    }

    function isCoinseller() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isCoinseller', false) == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      // Anyone authenticated can read profiles (needed for discovery/chat)
      allow read: if isAuthenticated();
      
      // Only the owner can create their initial profile
      allow create: if isOwner(userId);

      // Owner or Admin can update profile data
      allow update: if isOwner(userId) || isAdmin();

      // Transactions subcollection
      match /transactions/{transactionId} {
        // Owner, Admin, or Support can view transaction history
        allow read: if isOwner(userId) || isAdmin() || isSupport();
        // Any authenticated user can create a transaction (e.g. for gifting)
        // Note: Real balance security is enforced via RTDB transactions
        allow create: if isAuthenticated();
      }

      match /blockedUsers/{blockedId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, delete: if isAdmin() || isSupport();
    }

    match /calls/{chatId} {
      allow read, write: if isAuthenticated() && (
        chatId.split('_')[0] == request.auth.uid ||
        chatId.split('_')[1] == request.auth.uid
      );
    }

    match /partyRooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
