rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/userProfiles/$(userId)).data;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isAdmin', false) == true;
    }

    function isSupport() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isSupport', false) == true;
    }

    function isCoinseller() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && getUserData(request.auth.uid).get('isCoinseller', false) == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isOwner(userId) && (
        !request.resource.data.hasAny(['isAdmin', 'isCoinseller', 'isSupport']) || 
        (request.resource.data.get('isAdmin', false) == false && 
         request.resource.data.get('isCoinseller', false) == false && 
         request.resource.data.get('isSupport', false) == false)
      );

      allow update: if (
        isOwner(userId) && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isCoinseller', 'isSupport'])
        )
      ) || isAdmin();

      allow delete: if isOwner(userId) || isAdmin();

      match /transactions/{transactionId} {
        // Robust permission check for transactions subcollection
        allow get, list: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isSupport());
        allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isCoinseller());
      }

      match /blockedUsers/{blockedId} {
        allow get: if isAuthenticated() && (request.auth.uid == userId || request.auth.uid == blockedId);
        allow list: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, delete: if isAdmin() || isSupport();
    }

    match /calls/{chatId} {
      allow read, write: if isAuthenticated() && (
        chatId.split('_')[0] == request.auth.uid ||
        chatId.split('_')[1] == request.auth.uid
      );
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}